{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declarationMap": false,
    "sourceMap": false,
    "moduleResolution": "node"
  },
  "tsc-alias": {
    "resolveFullPaths": true,
    "replacers": {
      "exampleReplacer": {
        "enabled": true
      }
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
